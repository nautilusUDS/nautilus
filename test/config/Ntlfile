# ==============================================================================
# NAUTILUS ADVANCED TEST SUITE
# Purpose: Comprehensive validation of routing, expansion, and middlewares.
# ==============================================================================

# ------------------------------------------------------------------------------
# SECTION 1: SYSTEM & DIAGNOSTICS
# Testing: Virtual services, dynamic response generation, and diagnostic headers.
# ------------------------------------------------------------------------------

# Diagnostic Route for Integration Tests
GET */debug/health $ok("Infrastructure-OK")
    $SetHeader("X-Nautilus-Mode", "Diagnostic")

# Health and Monitoring
# Path Example: localhost/sys/health or 127.0.0.1/sys/stats
GET [localhost|127.0.0.1]/sys/[health|stats|metrics|status] $ok("System-Active")
    $Log("SYS_CHECK")
    $SetHeader("X-Nautilus-Version", "1.0.0-Beta")
    $SetHeader("X-Service-Class", "Infra")

# Request Inspection (Mirroring)
# Returns the full request context for debugging
[localhost|127.0.0.1]/inspect $echo
    $Log("INSPECT_REQ")

# ------------------------------------------------------------------------------
# SECTION 2: API SERVICES (VERSIONED & MODULAR)
# Testing: Cartesian product expansion and middleware inheritance.
# Total permutations: 2 (host) * 3 (version) * 2 (module) * 3 (action) = 36 rules.
# ------------------------------------------------------------------------------

# Main API Gateway
# Path Example: localhost/api/v2/billing/invoice
* [localhost|127.0.0.1]/api/[v1|v2|v3]/[auth|billing]/[create|query|cancel] backend
    $BasicAuth("developer", "dev-secret")
    $PathTrimPrefix("/api")
    $RateLimit(50, "10s")
    $Log("API_ACCESS")

# ------------------------------------------------------------------------------
# SECTION 3: NESTED EXPANSION & BOUNDARY CASES
# Testing: Deeply nested brackets and optional slash normalization.
# ------------------------------------------------------------------------------

# Complex Host/Path Nesting
# Matches: prod.api.io/v1/data, stage.api.io/v1/data, etc.
GET [[prod|stage].|]api.io/v1/data[/|] backend
    $SetHeader("X-Env-Type", "Hybrid")
    $Log("NESTED_TEST")

# ------------------------------------------------------------------------------
# SECTION 4: VIRTUAL UTILITY & ERROR SIMULATION
# Testing: Built-in error handling and status code mapping.
# ------------------------------------------------------------------------------

# Failure Suite
# Path Example: localhost/error/502
[localhost|127.0.0.1]/error/[400|403|404|500|502|503] $err
    $Log("ERROR_SIM")

# Maintenance & Control Plane
# Restrict access to local admin only
POST [localhost|127.0.0.1]/admin/[cluster|node]/[reload|drain|verify] $ok("Command-Executed")
    $BasicAuth("root", "admin-pass")
    $IPAllow("127.0.0.1/32")
    $SetHeader("X-Audit-Required", "true")

# ------------------------------------------------------------------------------
# SECTION 5: STATIC CONTENT & OPTIMIZATION
# Testing: Resource grouping and caching headers.
# ------------------------------------------------------------------------------

# Static Asset Pipeline
# Matches: 127.0.0.1/assets/lib/core.js, etc.
GET [localhost|127.0.0.1]/assets/[lib|css|media]/[core|app|vendor][.js|.css|.svg] backend
    $SetHeader("Cache-Control", "max-age=86400, immutable")
    $SetHeader("Access-Control-Allow-Origin", "*")

# ------------------------------------------------------------------------------
# SECTION 6: SECURITY & ACCESS CONTROL
# Testing: Pattern-based blocking and security middleware.
# ------------------------------------------------------------------------------

# Block Sensitive Patterns
# Immediately terminate requests to sensitive files
* [localhost|127.0.0.1]/[.env|.git|config.json|id_rsa|passwd] $err("Access Denied")
    $Log("SECURITY_VIOLATION")

# Anti-Scanning Honeytoken
[localhost|127.0.0.1]/wp-[login|admin|config].php $err("Threat-Detected")
    $Log("SCAN_ATTEMPT")

# ------------------------------------------------------------------------------
# SECTION 7: LEGACY ADAPTERS
# Testing: Path rewriting and header transformation.
# ------------------------------------------------------------------------------

# Legacy API Bridge
[localhost|127.0.0.1]/old-api/v0 backend
    $RewritePath("/old-api/v0", "/api/v1")
    $SetHeader("X-Legacy-Mode", "transformed")
    $Log("LEGACY_BRIDGE")

# ------------------------------------------------------------------------------
# SECTION 8: GLOBAL FALLBACK
# Testing: Catch-all logic for unmatched traffic within the domain.
# ------------------------------------------------------------------------------

# Default handler for Localhost
$ok("Nautilus-Default-Handler")
    $Log("DEFAULT_FALLBACK")

# Cross-cutting health check
*/health $health

# Global Metrics Endpoint
$metrics
