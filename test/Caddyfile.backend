{
    admin off
}

http://unix//var/run/nautilus/services/backend/node-1.sock {
    handle /api/v1/user/profile {
        respond "Welcome to Caddy Native UDS!"
    }
    handle /v1/data* {
        respond "Data OK"
    }
    handle /assets/* {
        respond "Asset OK"
    }
    handle /internal/* {
        header X-Internal-Call "True"
        respond "Internal OK"
    }
    handle {
        respond "Welcome to Caddy Native UDS!"
    }
}
